# =========================================
# 📡 Model Keys
# =========================================

# Google Gemini — ขอได้ที่ https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic Claude — ขอได้ที่ https://console.anthropic.com/ (optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =========================================
# 📁 Path
# =========================================

# โฟลเดอร์ที่ใช้เก็บ Obsidian Vault (ค่าเริ่มต้น: ./memories)
OBSIDIAN_VAULT_PATH=./memories

# =========================================
# 🏷️ Branding
# =========================================

# ชื่อกองทุน — ใช้ใน Bookkeeper system prompt (ค่าเริ่มต้น: "กองทุนส่วนตัว")
FUND_NAME=กองทุนส่วนตัว

# =========================================
# 🤖 Model Selection (optional — uncomment to override defaults)
# =========================================
# Current defaults (agents/manager_agent.py):
#   ทุก agent → gemini-3.1-flash-lite-preview
#   Fallback chain (core/llm_factory.FALLBACK_MODEL) → openai/gpt-oss-120b:free (cross-provider)
#
# MANAGER_MODEL=gemini-3.1-flash-lite-preview
# ROUTER_MODEL=gemini-3.1-flash-lite-preview      # ตัวที่รัน with_structured_output (RouterDecision)
# ARCHIVIST_MODEL=gemini-3.1-flash-lite-preview
# RESEARCHER_MODEL=gemini-3.1-flash-lite-preview
# BOOKKEEPER_MODEL=gemini-3.1-flash-lite-preview
# LLM_PROVIDER=google                              # override detect_provider() (claude/gemini/openrouter)

# Vault folders เพิ่มเติม (comma-separated) — เช่น 50_Crypto,60_Research/Drafts
# VAULT_EXTRA_FOLDERS=

# =========================================
# 📊 Data Sources
# =========================================

# FRED API — ขอได้ฟรีที่ https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# =========================================
# 🔭 LangSmith Observability (optional)
# =========================================

# เปิดใช้ LangSmith Tracing — ลบออกหรือตั้งเป็น false เพื่อปิด
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"

# LangSmith API Key — ขอได้ที่ https://smith.langchain.com/
LANGCHAIN_API_KEY=your_langsmith_api_key_here

# ชื่อ Project ใน LangSmith Dashboard
LANGCHAIN_PROJECT="Trinity-Wealth-Engine"